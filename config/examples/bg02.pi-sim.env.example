# Example environment for the Site B gateway simulator used by the Docker pi->mqtt->pi harness.
# This instance subscribes to MQTT and re-emits the payload through a simulated radio file.

# Device identity for the simulated Site B gateway.
SITE_CODE=b
DEVICE_CODE=bg02
GATEWAY_ID=bg02
DEVICE_ROLE=gateway

# The compose network exposes the broker under the service name mqtt-broker.
MQTT_HOST=mqtt-broker
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false
MQTT_TOPIC_PREFIX=mesh/v1

# Use tmp storage inside the disposable integration container.
STATE_DIR=/tmp/bg02-state
QUEUE_DB_PATH=/tmp/bg02-state/bg02-queue.sqlite3
LOG_FILE_PATH=/tmp/bg02-state/bg02.log
POLICY_FILE=/app/config/examples/gateway-policy.example.yaml

# This simulator is marked as radio-enabled so the MQTT-to-radio path is exercised.
RADIO_ENABLED=true
SERIAL_PORT=sim://bg02-radio
LOG_LEVEL=DEBUG
