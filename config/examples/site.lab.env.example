# Example local lab gateway configuration.
# This file is meant for workstation or laptop use when running the scaffold outside Docker.
# Values here are intentionally simple and local-first so you can validate config, storage,
# and MQTT behavior without needing private site secrets.

# Fleet identity. SITE_CODE and GATEWAY_ID must line up with the naming rules in the docs.
SITE_CODE=a
DEVICE_CODE=ag01
GATEWAY_ID=ag01
DEVICE_ROLE=gateway

# MQTT connectivity for the local lab broker.
# In this example the broker is expected on localhost because docker-compose.lab.yml
# maps the Mosquitto listener to 127.0.0.1:1883 on the workstation.
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false
MQTT_TOPIC_PREFIX=mesh/v1

# Local runtime state. These files are intentionally relative so the examples work
# from a normal checkout without editing absolute paths.
STATE_DIR=./state
QUEUE_DB_PATH=./state/ag01-queue.sqlite3
LOG_FILE_PATH=./state/ag01.log
POLICY_FILE=./config/examples/gateway-policy.example.yaml

# Radio settings. The lab example defaults to no live radio so the gateway can still
# be exercised for queueing, health, and publish behavior on a workstation.
RADIO_ENABLED=false
SERIAL_PORT=

# DEBUG is useful for lab exploration because it exposes publish, queue, and health flow.
LOG_LEVEL=DEBUG
