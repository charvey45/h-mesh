# Example environment for the Site A gateway simulator used by the Docker pi->mqtt->pi harness.
# This instance acts like a Pi-attached gateway that receives simulated RF and publishes to MQTT.

# Device identity for the simulated Site A gateway.
SITE_CODE=a
DEVICE_CODE=ag01
GATEWAY_ID=ag01
DEVICE_ROLE=gateway

# Inside the integration harness, the broker is another compose service named mqtt-broker.
MQTT_HOST=mqtt-broker
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false
MQTT_TOPIC_PREFIX=mesh/v1

# Use tmp storage inside the integration container because the harness is disposable.
STATE_DIR=/tmp/ag01-state
QUEUE_DB_PATH=/tmp/ag01-state/ag01-queue.sqlite3
LOG_FILE_PATH=/tmp/ag01-state/ag01.log
POLICY_FILE=/app/config/examples/gateway-policy.example.yaml

# RADIO_ENABLED=true plus a sim:// serial hint means "behave like a gateway with a radio"
# even though the harness uses a simulated radio boundary instead of USB hardware.
RADIO_ENABLED=true
SERIAL_PORT=sim://ag01-radio
LOG_LEVEL=DEBUG
