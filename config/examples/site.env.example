# Generic example environment for a real site gateway.
# Replace the broker endpoint, credentials, and path values with deployment-specific
# private configuration before using this on actual hardware.

# Device identity. The gateway ID must match the [site]g[hex][hex] naming convention.
SITE_CODE=a
DEVICE_CODE=ag01
GATEWAY_ID=ag01
DEVICE_ROLE=gateway

# Broker settings. These placeholders intentionally show a TLS-enabled deployment shape.
MQTT_HOST=example-broker
MQTT_PORT=8883
MQTT_USERNAME=replace-me
MQTT_PASSWORD=replace-me
MQTT_TLS_ENABLED=true
MQTT_TOPIC_PREFIX=mesh/v1

# Local state paths. Real deployments may point these to a dedicated persistent volume.
STATE_DIR=./state
QUEUE_DB_PATH=./state/queue.sqlite3
POLICY_FILE=./config/examples/gateway-policy.example.yaml

# Radio settings are disabled in the generic example because hardware attachment
# differs by deployment. A real site gateway would typically set RADIO_ENABLED=true
# and provide a serial port or stable device path.
RADIO_ENABLED=false
SERIAL_PORT=
LOG_LEVEL=INFO
