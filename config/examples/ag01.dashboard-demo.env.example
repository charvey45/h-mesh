# Example environment for the management demo stack.
# The dashboard demo uses ag01 as the observed gateway identity and publishes
# synthetic sensor traffic into the shared state directory mounted at /data/state.

# Device identity for the demo gateway context.
SITE_CODE=a
DEVICE_CODE=ag01
GATEWAY_ID=ag01
DEVICE_ROLE=gateway

# The demo stack points at the compose-managed Mosquitto broker.
MQTT_HOST=mqtt-broker
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false
MQTT_TOPIC_PREFIX=mesh/v1

# Persist state into the mounted host-backed volume so the dashboard can read it.
STATE_DIR=/data/state
QUEUE_DB_PATH=/data/state/ag01-queue.sqlite3
LOG_FILE_PATH=/data/state/ag01.log
POLICY_FILE=/app/config/examples/gateway-policy.example.yaml

# The clock sensor demo does not rely on a physical radio.
RADIO_ENABLED=false
SERIAL_PORT=
LOG_LEVEL=DEBUG
